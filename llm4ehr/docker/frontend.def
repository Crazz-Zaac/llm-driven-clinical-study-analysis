Bootstrap: docker
From: node:20-alpine

%post
    mkdir -p /app

%files
    ../frontend/package*.json /app/
    ../frontend/app /app/app
    ../frontend/components /app/components
    ../frontend/lib /app/lib
    ../frontend/public /app/public
    ../frontend/hooks /app/hooks
    ../frontend/styles /app/styles
    ../frontend/next.config.mjs /app/
    ../frontend/tsconfig.json /app/
    ../frontend/postcss.config.mjs /app/
    ../frontend/components.json /app/

%post
    cd /app
    npm ci --legacy-peer-deps
    npm run build

%environment
    NODE_ENV=production

%runscript
    exec npm start

%labels
    Author llm4ehr
    Version v1

CR_TOKEN=your-github-token-here

# Qdrant Configuration
QDRANT_URL=http://qdrant:6333
QDRANT_SECRET_KEY=your-qdrant-secret-key-here
QDRANT_COLLECTION_NAME=ehr_documents

# HuggingFace LLM Configuration
HF_API_KEY=your-huggingface-api-key
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.1

# LLM Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO